        <header/>
        <body>
            <trans-unit id="ce-wizard.tab.publications.title" xml:space="preserve">
                <source>Publications</source>
            </trans-unit>
            <trans-unit id="ce-wizard.ce.bibtex.title" xml:space="preserve">
                <source>Bibtex</source>
            </trans-unit>
			<trans-unit id="settings.bibtexUrl" xml:space="preserve">
                <source>URL (of bibtex file)</source>
            </trans-unit>
			<trans-unit id="settings.allow" xml:space="preserve">
                <source>Only display these (Allow)</source>
            </trans-unit>
			<trans-unit id="settings.deny" xml:space="preserve">
                <source>Do not display (Deny)</source>
            </trans-unit>
			<trans-unit id="settings.allow.all" xml:space="preserve">
                <source>- show all -</source>
            </trans-unit>
			<trans-unit id="settings.deny.all" xml:space="preserve">
                <source>- hide none -</source>
            </trans-unit>
			<trans-unit id="settings.filterType" xml:space="preserve">
                <source>Filter by publication type</source>
            </trans-unit>
			<trans-unit id="settings.filterType.doNotFilter" xml:space="preserve">
                <source>Display all</source>
            </trans-unit>
			<trans-unit id="settings.filterType.allow" xml:space="preserve">
                <source>Include only publication types from the following list</source>
            </trans-unit>
			<trans-unit id="settings.filterType.deny" xml:space="preserve">
                <source>Exclude publication types from the following list</source>
            </trans-unit>
			<trans-unit id="settings.filterByPublication" xml:space="preserve">
                <source>Publication types (multi-select mode)</source>
            </trans-unit>
			<trans-unit id="error.message.fetch.0" xml:space="preserve">
                <source>Bibtex content was fetched successfully.</source>
            </trans-unit>
			<trans-unit id="error.message.fetch.1" xml:space="preserve">
                <source>Error fetching Bibtex content. Please check if URL is correct and content can be loaded.</source>
            </trans-unit>
			<trans-unit id="error.message.fetch.2" xml:space="preserve">
                <source>No Bibtex content. Maybe the file is empty?</source>
            </trans-unit>
			<trans-unit id="error.message.fetch.3" xml:space="preserve">
                <source>Bibtex file is missing or could not be loaded.</source>
            </trans-unit>
			<trans-unit id="error.message.fetch.4" xml:space="preserve">
                <source>Invalid configuration: Wrong file type.</source>
            </trans-unit>
			<trans-unit id="error.message.fetch.5" xml:space="preserve">
                <source>Invalid configuration: Invalid URL or undefined URL.</source>
            </trans-unit>
			<trans-unit id="error.message.fetch.6" xml:space="preserve">
                <source>Could not fetch Bibtex from URL.</source>
            </trans-unit>
			<trans-unit id="error.message.fetch.unknown_result" xml:space="preserve">
                <source>Result of loading Bibtex file is currently unknown. Load page in Frontend to see more results here.</source>
            </trans-unit>
			<trans-unit id="last_fetched" xml:space="preserve">
                <source>Last fetched</source>
            </trans-unit>

			<!-- parse result errors -->
			<trans-unit id="error.message.parse.title" xml:space="preserve">
                <source>Invalid format in Bibtex file</source>
            </trans-unit>
			<trans-unit id="error.message.parse.1" xml:space="preserve">
                <source>A field "author" probably contains several authors, but these are probably not separated correctly.
					This usually leads to ugly errors in the displayed publication information.
				</source>
            </trans-unit>
			<trans-unit id="error.message.parse.tip.1" xml:space="preserve">
                <source>Several authors should be seperated by "and", not comma (","),
					for example author = {Marie Curie and Albert Einstein}.
					An organization should usually enclosed inside an additional pair of braces,
					for example author = {{FZI Forschungszentrum Informatik am Karlsruher Institut für Technologie}}.</source>
            </trans-unit>
			<!-- optional add a URL for more information -->
			<trans-unit id="error.message.parse.url.1" xml:space="preserve">
                <source>https://www.bibtex.com/f/author-field/</source>
            </trans-unit>
			<trans-unit id="error.message.parse.url.linktext.1" xml:space="preserve">
                <source>BibTeX field: author</source>
            </trans-unit>

			<!-- parse result error 2 -->
			<trans-unit id="error.message.parse.2" xml:space="preserve">
                <source>Missing field (year) in bibtex entry.</source>
            </trans-unit>
			<trans-unit id="error.message.parse.tip.2" xml:space="preserve">
                <source>For most publication types, a field "year" is required. Furthermore, this may be used for sorting.</source>
            </trans-unit>
			<!-- optional add a URL for more information -->
			<trans-unit id="error.message.parse.url.2" xml:space="preserve">
                <source>https://www.bibtex.com/f/year-field/</source>
            </trans-unit>
			<trans-unit id="error.message.parse.url.linktext.2" xml:space="preserve">
                <source>BibTeX field: year</source>
            </trans-unit>
        </body>
