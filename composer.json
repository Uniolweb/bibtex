{
	"name": "uniolweb/bibtex",
	"description": "TYPO3 extension for displaying publications from a source in bibtex format",
	"license": "GPL-2.0-or-later",
	"type": "typo3-cms-extension",
	"keywords": [
		"TYPO3",
		"bibtex"
	],
	"require": {
		"php": "^8.2",
		"sypets/osbibx-parser": "dev-main || ^4.0.0",
		"typo3/cms-backend": "^13.4",
		"typo3/cms-core": "^13.4",
		"typo3/cms-extbase": "^13.4",
		"typo3/cms-fluid": "^13.4",
		"typo3/cms-frontend": "^13.4",
		"uniolweb/uniollib": "dev-main"
	},
	"autoload": {
		"psr-4": {
			"Uniolweb\\Bibtex\\": "Classes/"
		}
	},
	"config": {
		"sort-packages": true,
		"vendor-dir": ".Build/vendor",
		"bin-dir": ".Build/bin",
		"gitlab-domains": ["gitlab.uni-oldenburg.de"],
		"allow-plugins": {
			"phpstan/extension-installer": true,
			"typo3/class-alias-loader": true,
			"typo3/cms-composer-installers": true
		}
	},
	"extra": {
		"typo3/cms": {
			"extension-key": "bibtex",
			"cms-package-dir": "{$vendor-dir}/typo3/cms",
			"web-dir": ".Build/Web"
		}
	},
	"require-dev": {
		"friendsofphp/php-cs-fixer": "^3.0.2",
		"phpstan/phpstan": "^1 || ^2",
		"ssch/typo3-rector": "^2.6 || ^3",
		"typo3/testing-framework": "^7 || ^8"
	},
	"scripts": {
		"cgl:check": [
			"rm -f .php-cs-fixer.cache;php .Build/bin/php-cs-fixer fix -v --config Build/php-cs-fixer.php --path-mode intersection --dry-run ."
		],
		"cgl:fix": [
			"rm -rf .php-cs-fixer.cache;php .Build/bin/php-cs-fixer fix -v --config Build/php-cs-fixer.php --path-mode intersection ."
		],
		"phpstan": [
			"@php .Build/bin/phpstan analyse --no-progress --no-interaction --memory-limit 4G -c Build/phpstan/phpstan.neon"
		],
		"phpstan:baseline": [
			"@php .Build/bin/phpstan analyse --no-progress --no-interaction --memory-limit 4G -c Build/phpstan/phpstan.neon --generate-baseline=Build/phpstan/phpstan-baseline.neon"
		],
		"lint": [
			"find Classes -name \"*.php\"  | while read i;do php -dxdebug.mode=off -l $i;done > /dev/null"
		],
		"rector:check": [
			"@php .Build/bin/rector process --dry-run"
		],
		"rector:fix": [
			"@php .Build/bin/rector process"
		],
		"build:cleanup": [
			"git reset --hard",
			"git clean -xfd"
		],
		"deploy:ter:setup": [
			"@composer global require clue/phar-composer typo3/tailor"
		],
		"build:setup": [
			"@composer global require clue/phar-composer"
		],
		"build:vendors": [
			"(mkdir -p /tmp/vendors && cd /tmp/vendors && composer init -n --name=\"tmp/tmp\" --require=\"sypets/osbibx-parser:dev-main\" && composer install && composer global exec phar-composer build -v)",
			"cp /tmp/vendors/tmp.phar ./Resources/Private/libraries.phar",
			"echo \"require 'phar://' . \\TYPO3\\CMS\\Core\\Utility\\ExtensionManagementUtility::extPath('$(composer config extra.typo3/cms.extension-key)') . 'Resources/Private/libraries.phar/vendor/autoload.php';\" >> ext_localconf.php"
		],
		"deploy:ter:upload": [
			"composer global exec -v -- tailor ter:publish --comment \"$(git tag -l --format='%(contents)' $TAG)\" $TAG"
		],
		"deploy:ter": [
			"@build:cleanup",
			"@deploy:ter:setup",
			"@build:vendors",
			"@deploy:ter:upload"
		],
		"build:non-composer-local": [
			"@build:cleanup",
			"@build:setup",
			"@build:vendors"
		]
	}
}
