 file = {Schlamelcher et al. - 2015 - Dynamic DICOM configuration in a service-oriented medical device architecture:C\:\\Users\\NilsV\\AppData\\Local\\Mendeley Ltd\\Mendeley Desktop\\Downloaded\\Schlamelcher et al. - 2015 - Dynamic DICOM configuration in a service-oriented medical device architecture.pdf:pdf}
}


