@proceedings{Brell.2010b,
 abstract = {This paper addresses the need of a quantitative and objective evaluation of cartilage with minimal imp act on the patient. Diagnoses and treatments of osteoarthritis are currently limited to invasive tissue treatments and/or (cartilage) transplan-tation.  The  diagnosis  often  occurs  in  an  advanced  state  of  the  course  of  disease  and  the  treatment  is long,  painful,  and expensive  and  most  do  necessitate  the  patient  to  undergo  a  surgery.  There  is  therefore  the  need  for  an   early  detection method,  which  should  allow  less  minimally  invasive treatments  at  an  early  stage,  before  the  cartilage has  been  perma-nently altered.  This paper presents a new method which is capable to provide nanometer scale measurem ents of biome-chanical properties, such as visco-elastic modulus and surface roughness. This method adds quantitativ e value to the di-agnosis in an early stage of the disease.  In this paper the concept and results of the first proof of  concept experiment are presented showing the high potential of the approac h by representing literature values.},
 year = {2010},
 title = {Automatisierte Viskoelastizit{\"a}ts- und Rauigkeitsmessungen zur Fr{\"u}hdiagnose bei Arthrose (2010)},
