 year = {2012},
 doi = {10.1109/EMBC.2012.6346028},
 file = {23365989:\\\\www.ncbi.nlm.nih.gov\\pubmed\\23365989:;Helmer et al. - 2012 - A system for the model based emergency detection and communication for the telerehabilitation training of cardiop:C\:\\Users\\NilsV\\AppData\\Local\\Mendeley Ltd\\Mendeley Desktop\\Downloaded\\Helmer et al. - 2012 - A system for the model based emergency detection and communication for the telerehabilitation training of cardiop.pdf:pdf}
