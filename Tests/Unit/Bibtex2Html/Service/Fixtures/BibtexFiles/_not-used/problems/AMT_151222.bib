 file = {Welge et al. - 2014 - AAL-Onto - A Formal Representation of RAALI Integration Profiles:C\:\\Users\\NilsV\\AppData\\Local\\Mendeley Ltd\\Mendeley Desktop\\Downloaded\\Welge et al. - 2014 - AAL-Onto - A Formal Representation of RAALI Integration Profiles.pdf:pdf}
