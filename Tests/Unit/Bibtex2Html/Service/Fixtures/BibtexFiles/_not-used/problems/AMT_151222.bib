 pages = {83190A},
 volume = {83190A},
 publisher = {SPIE},
 editor = {Boonn, William W. and Liu, Brent J.},
 booktitle = {Medical Imaging 2012: Advanced PACS-based Imaging Informatics and Therapeutic Applications},
 year = {2012},
 address = {San Diego, California, USA},
 doi = {10.1117/12.910872},
 file = {El Gazzar et al. - 2012 - A Comprehensive Framework for Quality Assurance in Clinical Trials:C\:\\Users\\NilsV\\AppData\\Local\\Mendeley Ltd\\Mendeley Desktop\\Downloaded\\El Gazzar et al. - 2012 - A Comprehensive Framework for Quality Assurance in Clinical Trials.pdf:pdf}
