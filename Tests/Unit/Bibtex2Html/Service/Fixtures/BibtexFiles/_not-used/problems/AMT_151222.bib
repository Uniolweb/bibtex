 isbn = {978-3-642-37988-8},
 editor = {Wichert, Reiner and Klausing, Helmut},
 booktitle = {Ambient Assisted Living: 6. AAL-Kongress 2013 Berlin, Germany, January 22. - 23. , 2013},
 year = {2014},
 address = {Berlin, Heidelberg},
