 file = {DKE-Arbeitskreis STD 1811.0.12 â€žAAL-Interoperabilitätâ€œ - 2013 - Leitfaden interoperable Assistenzsysteme - vom Szenario zur Anforderung.:C\:\\Users\\NilsV\\AppData\\Local\\Mendeley Ltd\\Mendeley Desktop\\Downloaded\\DKE-Arbeitskreis STD 1811.0.12 â€žAAL-Interoperabilitätâ€œ - 2013 - Leitfaden interoperable Assistenzsysteme - vom Szenario zur Anforderung..pdf:pdf}
}


