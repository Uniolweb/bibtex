@inproceedings{Weber.2003c,
 abstract = {We report work on a newly developed and ultra compact mobile viewing device, called NaviView to display medical imaging data (i.e. from a computer tomograph-CT) in situ. The system comprises an optical tracking system to detect both the patients and the viewing devices position and display a proportionable part of the medical image data on a mobile viewing device. This article describes experiments carried out to evaluate the overlay precision of two different imaging modalities (i.e. live video and CT) being visualized.},
