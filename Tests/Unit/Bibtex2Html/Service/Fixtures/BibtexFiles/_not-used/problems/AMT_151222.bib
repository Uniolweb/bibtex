 file = {Lien et al. - 2011 - Open source tools for standardized privacy protection of medical images:C\:\\Users\\NilsV\\AppData\\Local\\Mendeley Ltd\\Mendeley Desktop\\Downloaded\\Lien et al. - 2011 - Open source tools for standardized privacy protection of medical images.pdf:pdf}
