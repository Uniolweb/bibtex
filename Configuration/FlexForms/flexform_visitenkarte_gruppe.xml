<T3DataStructure>
    <sheets>
        <sDEF>
            <ROOT>
                <TCEforms>
                    <sheetTitle>Optionen</sheetTitle>
                </TCEforms>
                <type>array</type>
                <el>
                    <settings.group>
                    <TCEforms>
                        <label>Anzuzeigende Gruppe</label>
                            <config>
                                <type>select</type>
                                <itemsProcFunc>tx_studipol_helper->instituteGroups</itemsProcFunc>
                            </config>
                    </TCEforms>
                    </settings.group>
					<settings.template>
                        <TCEforms>
                            <label>Verwendetes Layout</label>
                                <config>
                                    <type>select</type>
                                    <itemsProcFunc>tx_studipol_helper->visitenkarteLayouts</itemsProcFunc>
                                </config>
                        </TCEforms>
                    </settings.template>
					<settings.showall>
						<TCEforms>
							<label>Zeige alle Felder</label>
							<onChange>reload</onChange>
							<config>
							  <type>check</type>
							  <default>0</default>
							</config>
						</TCEforms>
                    </settings.showall>
					<settings.showaktuelles>
						<TCEforms>
							<label>Zeige Aktuelles</label>
							<displayCond>FIELD:settings.showall:REQ:false</displayCond>
							<config>
							  <type>check</type>
							</config>
						</TCEforms>
                    </settings.showaktuelles>
					<settings.showschwerpunkt>
						<TCEforms>
							<label>Zeige Schwerpunkt</label>
							<displayCond>FIELD:settings.showall:REQ:false</displayCond>
							<config>
							  <type>check</type>
							</config>
						</TCEforms>
                    </settings.showschwerpunkt>
					<settings.showpresse>
						<TCEforms>
							<label>Zeige Presselink</label>
							<displayCond>FIELD:settings.showall:REQ:false</displayCond>
							<config>
							  <type>check</type>
							</config>
						</TCEforms>
                    </settings.showpresse>
					<settings.showavatar>
						<TCEforms>
							<label>Zeige Avatar</label>
							<displayCond>FIELD:settings.showall:REQ:false</displayCond>
							<config>
							  <type>check</type>
							</config>
						</TCEforms>
                    </settings.showavatar>
                    <settings.showemail>
						<TCEforms>
							<label>Zeige EMail</label>
							<displayCond>FIELD:settings.showall:REQ:false</displayCond>
							<config>
							  <type>check</type>
							</config>
						</TCEforms>
                    </settings.showemail>
                    <settings.showhomepage>
						<TCEforms>
							<label>Zeige Homepage</label>
							<displayCond>FIELD:settings.showall:REQ:false</displayCond>
							<config>
							  <type>check</type>
							</config>
						</TCEforms>
                    </settings.showhomepage>
                    <settings.showinstitute>
						<TCEforms>
							<label>Zeige Einrichtung</label>
							<displayCond>FIELD:settings.showall:REQ:false</displayCond>
							<config>
							  <type>check</type>
							</config>
						</TCEforms>
                    </settings.showinstitute>
                    <settings.showroom>
                        <TCEforms>
                            <label>Zeige Raum</label>
							<displayCond>FIELD:settings.showall:REQ:false</displayCond>
                            <config>
                              <type>check</type>
                            </config>
                        </TCEforms>
                    </settings.showroom>
					<settings.showconsultation>
                        <TCEforms>
                            <label>Zeige Sprechzeiten</label>
							<displayCond>FIELD:settings.showall:REQ:false</displayCond>
                            <config>
                              <type>check</type>
                            </config>
                        </TCEforms>
                    </settings.showconsultation>
                    <settings.shownumbers>
                        <TCEforms>
                            <label>Zeige Telefon/Fax</label>
							<displayCond>FIELD:settings.showall:REQ:false</displayCond>
                            <config>
                              <type>check</type>
                            </config>
                        </TCEforms>
                    </settings.shownumbers>
                    <settings.showcourses>
                        <TCEforms>
                            <label>Zeige Veranstaltungen</label>
							<displayCond>FIELD:settings.showall:REQ:false</displayCond>
                            <config>
                              <type>check</type>
                            </config>
                        </TCEforms>
                    </settings.showcourses>
                </el>
            </ROOT>
        </sDEF>
    </sheets>
</T3DataStructure>